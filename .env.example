# API Settings
API_V1_PREFIX=/api/v1
PROJECT_NAME=GraphFleet
VERSION=1.0.0

# Project Settings
PROJECT_DIR=./data
LOG_LEVEL=INFO


# GraphRAG Settings
GRAPHRAG_API_KEY="fcfff4cda4ae4277aa9bac2d6d740431"
GRAPHRAG_API_BASE="https://sweden-azure-oai.openai.azure.com"
GRAPHRAG_API_VERSION="2024-07-18"
GRAPHRAG_DEPLOYMENT_NAME="gpt-4o-mini"
GRAPHRAG_API_TYPE="azure_openai"
GRAPHRAG_EMBEDDING_MODEL="text-embedding-3-large"
GRAPHRAG_LLM_MODEL="gpt-4o-mini"
GRAPHRAG_EMBEDDING_TYPE="azure_openai_embedding"
GRAPHRAG_EMBEDDING_KEY="fcfff4cda4ae4277aa9bac2d6d740431"
GRAPHRAG_EMBEDDING_ENDPOINT="https://sweden-azure-oai.openai.azure.com"
GRAPHRAG_EMBEDDING_DEPLOYMENT_NAME="text-embedding-3-large"

# Vector Store Settings
VECTOR_STORE_TYPE=lancedb
VECTOR_STORE_PATH=${PROJECT_DIR}/indexes/lancedb

# Query Settings
MAX_RESULTS=10
SIMILARITY_THRESHOLD=0.7
MAX_HOPS=2

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# Security Settings
ALLOWED_HOSTS=["*"]
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
